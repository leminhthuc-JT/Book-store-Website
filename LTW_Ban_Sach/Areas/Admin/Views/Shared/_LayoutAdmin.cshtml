<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <link rel="stylesheet" href="~/Content/bootstrap.css" />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="/Content/Style.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" integrity="sha512-..." crossorigin="anonymous" referrerpolicy="no-referrer" />
    <script src="~/Scripts/jquery-3.7.1.js"></script>
    <script src="~/Scripts/jquery.validate.js"></script>
    <script src="~/Scripts/jquery.validate.unobtrusive.js"></script>
    <title>@ViewBag.Title</title>
</head>
<body style="background-color: var(--bg-color)">
    <div>
        <nav class="navbar navbar-expand navbar-dark fixed-top"
             style="background-image: var(--gradient-tech); height: 70px; ">
            <div class="container">
                <a class="navbar-brand"
                   href="/Home/Index">
                    <div class="text-light d-flex">
                        <i class="fa-solid fa-book"
                           style="font-size: 40px; margin-top: 20px;">
                        </i>
                        <div>
                            <p style="margin-bottom: -10px; font-size: 36px; font-weight: bold">
                                BOOK
                            </p>
                            <p style="font-size: 16px; font-weight: 100;">
                                STORE
                            </p>
                        </div>
                    </div>
                </a>
                <div>
                    <ul class="navbar-nav">
                        <li class="nav-item m-3"
                            style="margin-right: 30px;">
                            <a class="nav-link"
                               href="@Url.Action("Index","Home")"
                               style="font-size: 18px; font-weight: 300;">
                                HOME
                            </a>
                        </li>
                        <li class="nav-item m-3" style="margin-right: 30px;">
                            <a class="nav-link"
                               href="@Url.Action("Index","Product")" style="font-size: 18px; font-weight: 300;">
                                PRODUCTS
                            </a>
                        </li>
                        <li class="nav-item m-3"
                            style="margin-right: 30px;">
                            <a class="nav-link"
                               href="@Url.Action("Index","Order")"
                               style="font-size: 18px; font-weight: 300;">
                                ORDER
                            </a>
                        </li>
                        <li class="nav-item m-3"
                            style="margin-right: 30px;">
                            <a class="nav-link"
                               href="@Url.Action("Index","Users")"
                               style="font-size: 18px; font-weight: 300;">
                                USERS
                            </a>
                        </li>
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item m-3 line">
                                <a class="nav-link" href="/Home/ProFile?Name=@User.Identity.Name" style="font-size: 18px; font-weight: 300;"> Profile of @User.Identity.Name </a>
                            </li>
                            <li class="nav-item m-3 line">
                                <a class="nav-link" href="#"><i class="fa-solid fa-cart-arrow-down" style="font-size: 18px; font-weight: 300; "></i></a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item dropdown_list m-3">
                                <a class="nav-link"
                                   href="#"
                                   style="font-size: 18px; font-weight: 300;"
                                   role="button"
                                   data-bs-toggle="dropdown"
                                   aria-expanded="false">
                                    ACCOUNT
                                </a>
                                <ul class="dropdown_menu">
                                    <li>
                                        <a class="dropdown_item"
                                           href="/Account/Regester">
                                            Register
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown_item"
                                           href="/Account/Login">
                                            Login
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }

                    </ul>
                </div>
            </div>
        </nav>
    </div>
    <div>
        @RenderBody()
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

