@model LTW_Ban_Sach.Identity.AppUser
@{
    ViewBag.Title = "Sửa tài khoản";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

<style>
    :root {
        --gradient-tech: linear-gradient(90deg, rgba(0,77,77,1), rgba(0,25,47,1));
        --primary-color: rgba(0,77,77,1);
        --secondary-color: rgba(0,25,47,1);
    }

    .edit-user-container {
        max-width: 900px;
        margin: 30px auto;
        padding: 0 20px;
    }

    .page-header {
        background: var(--gradient-tech);
        color: white;
        padding: 20px;
        border-radius: 15px 15px 0 0;
        box-shadow: 0 5px 20px rgba(0, 77, 77, 0.3);
        display: flex;
        align-items: center;
        gap: 20px;
    }

    .back-btn {
        width: 45px;
        height: 45px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        text-decoration: none;
        transition: all 0.3s ease;
        margin-top:35px;
    }

    .back-btn:hover {
        background: rgba(255, 255, 255, 0.3);
        transform: translateX(-5px);
        color: white;
    }

    .page-header h2 {
        margin: 0;
        font-size: 28px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 12px;
        margin-top:35px;
    }

    .form-card {
        background: white;
        border-radius: 0 0 15px 15px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        overflow: hidden;
    }

    .form-body {
        padding: 40px;
    }

    .alert {
        padding: 15px 20px;
        border-radius: 10px;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 12px;
        font-weight: 500;
    }

    .alert-success {
        background: #d4edda;
        color: #155724;
        border: 1px solid #c3e6cb;
    }

    .alert-info {
        background: #d1ecf1;
        color: #0c5460;
        border: 1px solid #bee5eb;
    }

    .alert i {
        font-size: 20px;
    }

    .user-id-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(0, 77, 77, 0.1);
        padding: 10px 20px;
        border-radius: 20px;
        font-weight: 600;
        color: var(--primary-color);
        margin-bottom: 25px;
        border: 2px solid rgba(0, 77, 77, 0.2);
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 25px;
    }

    .form-grid.two-column {
        grid-template-columns: 1fr 1fr;
    }

    .form-section {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .form-section label {
        font-weight: 600;
        color: var(--secondary-color);
        font-size: 14px;
        display: flex;
        align-items: center;
        gap: 8px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .form-section label i {
        color: var(--primary-color);
        font-size: 16px;
    }

    .form-section label .required {
        color: #e74c3c;
        margin-left: 3px;
    }

    .input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }

    .input-wrapper i {
        position: absolute;
        left: 15px;
        color: #999;
        font-size: 16px;
        z-index: 1;
    }

    .form-control {
        width: 100%;
        padding: 14px 15px 14px 45px;
        border: 2px solid #e0e0e0;
        border-radius: 10px;
        font-size: 15px;
        transition: all 0.3s ease;
        background: #f8f9fa;
    }

    .form-control:focus {
        outline: none;
        border-color: var(--primary-color);
        background: white;
        box-shadow: 0 0 0 4px rgba(0, 77, 77, 0.1);
    }

    .form-control::placeholder {
        color: #aaa;
    }

    .form-control:disabled {
        background: #e9ecef;
        cursor: not-allowed;
        color: #6c757d;
    }

    .section-divider {
        margin: 30px 0;
        border: none;
        height: 2px;
        background: linear-gradient(to right, transparent, rgba(0, 77, 77, 0.2), transparent);
    }

    .section-title {
        color: var(--primary-color);
        font-size: 18px;
        font-weight: 600;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
        padding-bottom: 10px;
        border-bottom: 2px solid rgba(0, 77, 77, 0.2);
    }

    .section-title i {
        font-size: 22px;
    }

    .avatar-section {
        display: flex;
        align-items: center;
        gap: 20px;
        padding: 20px;
        background: rgba(0, 77, 77, 0.05);
        border-radius: 12px;
        border: 2px dashed rgba(0, 77, 77, 0.3);
    }

    .avatar-preview {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        object-fit: cover;
        border: 4px solid white;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
    }

    .avatar-info {
        flex: 1;
    }

    .avatar-info p {
        margin: 0;
        color: #666;
        font-size: 13px;
    }

    .form-actions {
        display: flex;
        gap: 15px;
        padding: 30px 40px;
        background: #f8f9fa;
        border-top: 2px solid #e0e0e0;
        margin-top: 30px;
    }

    .btn-submit, .btn-cancel {
        padding: 14px 30px;
        border-radius: 10px;
        font-size: 15px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s ease;
        border: none;
        cursor: pointer;
        text-decoration: none;
    }

    .btn-submit {
        background: var(--gradient-tech);
        color: white;
        width: 190px;
    }

    .btn-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(0, 77, 77, 0.3);
    }

    .btn-cancel {
        background: #6c757d;
        color: white;
    }

    .btn-cancel:hover {
        background: #5a6268;
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(108, 117, 125, 0.3);
        color: white;
        text-decoration: none;
    }

</style>

<div class="edit-user-container">
    <div class="page-header">
        <a href="javascript:history.back()" class="back-btn">
            <i class="fa-solid fa-arrow-left"></i>
        </a>
        <h2>
            <i class="fa-solid fa-user-pen"></i>
            Chỉnh Sửa Tài Khoản
        </h2>
    </div>

    <div class="form-card">
        <div class="form-body">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success">
                    <i class="fa-solid fa-circle-check"></i>
                    @TempData["SuccessMessage"]
                </div>
            }

            <div class="user-id-badge">
                <i class="fa-solid fa-fingerprint"></i>
                User ID: @Model.Id
            </div>

            <form method="post">
                <input type="hidden" name="Id" value="@Model.Id" />

                <!-- Account Information Section -->
                <div class="section-title">
                    <i class="fa-solid fa-id-card"></i>
                    Thông tin tài khoản
                </div>

                <div class="form-grid two-column">
                    <div class="form-section">
                        <label>
                            <i class="fa-solid fa-envelope"></i>
                            Email
                            <span class="required">*</span>
                        </label>
                        <div class="input-wrapper">
                            <i class="fa-solid fa-envelope"></i>
                            <input name="Email" class="form-control" required value="@Model.Email" placeholder="Nhập địa chỉ email" />
                        </div>
                    </div>

                    <div class="form-section">
                        <label>
                            <i class="fa-solid fa-user"></i>
                            Họ tên
                            <span class="required">*</span>
                        </label>
                        <div class="input-wrapper">
                            <i class="fa-solid fa-user"></i>
                            <input name="FullName" class="form-control" required value="@Model.UserName" placeholder="Nhập họ tên" />
                        </div>
                    </div>
                </div>

                <hr class="section-divider" />

                <!-- Contact Information Section -->
                <div class="section-title">
                    <i class="fa-solid fa-address-book"></i>
                    Thông tin liên hệ
                </div>

                <div class="form-grid two-column">
                    <div class="form-section">
                        <label>
                            <i class="fa-solid fa-mobile-screen"></i>
                            Số điện thoại
                        </label>
                        <div class="input-wrapper">
                            <i class="fa-solid fa-mobile-screen"></i>
                            <input name="PhoneNumber" class="form-control" value="@Model.PhoneNumber" placeholder="Nhập số điện thoại" />
                        </div>
                    </div>

                    <div class="form-section">
                        <label>
                            <i class="fa-solid fa-location-dot"></i>
                            Địa chỉ
                        </label>
                        <div class="input-wrapper">
                            <i class="fa-solid fa-location-dot"></i>
                            <input name="address" class="form-control" value="@Model.Address" placeholder="Nhập địa chỉ" />
                        </div>
                    </div>
                </div>

                <hr class="section-divider" />

                <!-- Avatar Section -->
                <div class="section-title">
                    <i class="fa-solid fa-image"></i>
                    Ảnh đại diện
                </div>

                <div class="avatar-section">
                    @if (!string.IsNullOrEmpty(Model.Avatar))
                    {
                        <img src="@Url.Content(Model.Avatar)" alt="Avatar" class="avatar-preview" onerror="this.src='https://via.placeholder.com/100?text=No+Image'" />
                    }
                    else
                    {
                        <img src="https://via.placeholder.com/100?text=No+Avatar" alt="Avatar" class="avatar-preview" />
                    }

                    <div class="avatar-info">
                        <div class="form-section" style="margin: 0;">
                            <label style="margin-bottom: 8px;">
                                <i class="fa-solid fa-link"></i>
                                URL ảnh đại diện
                            </label>
                            <div class="input-wrapper">
                                <i class="fa-solid fa-link"></i>
                                <input name="avt" class="form-control" value="@Model.Avatar" placeholder="Nhập URL ảnh đại diện" />
                            </div>
                        </div>
                        <p style="margin-top: 10px;">
                            <i class="fa-solid fa-circle-info"></i>
                            Nhập đường dẫn URL của ảnh đại diện hoặc để trống
                        </p>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-submit">
                        <i class="fa-solid fa-floppy-disk"></i>
                        Lưu thay đổi
                    </button>
                    <a href="javascript:history.back()" class="btn-cancel">
                        <i class="fa-solid fa-xmark"></i>
                        Hủy bỏ
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>