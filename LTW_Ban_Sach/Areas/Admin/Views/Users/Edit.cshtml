@model LTW_Ban_Sach.Identity.AppUser

@{
    ViewBag.Title = "Sửa tài khoản";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<h2>Sửa tài khoản</h2>

<form method="post">

    <input type="hidden" name="Id" value="@Model.Id" />

    <div class="form-group">
        <label>Email</label>
        <input name="Email" class="form-control" required value="@Model.Email" />
    </div>

    <div class="form-group">
        <label>Họ tên</label>
        <input name="FullName" class="form-control" required value="@Model.UserName" />
    </div>

    <div class="form-group">
        <label>Số điện thoại</label>
        <input name="PhoneNumber" class="form-control" value="@Model.PhoneNumber" />
    </div>
    <div class="form-group">
        <label>Số điện thoại</label>
        <input name="address" class="form-control" value="@Model.Address" />
    </div>
    <div class="form-group">
        <label>Ảnh đại diện</label>
        <input name="avt" class="form-control" value="@Model.Avatar" />
    </div>

    <button type="submit" class="btn btn-success">Lưu</button>
</form>


