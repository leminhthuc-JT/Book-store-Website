@model List<LTW_Ban_Sach.Models.Cart>
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
}

<style>
    .gradient-tech {
        background: linear-gradient(90deg, rgba(0,77,77,1), rgba(0,77,77,1), rgba(0,25,47,1), rgba(0,25,47,1), rgba(10,25,47,1));
    }

    .cart-container {
        margin-top: 100px;
        margin-bottom: 40px;
        padding: 20px;
    }

    .cart-header {
        background: linear-gradient(90deg, rgba(0,77,77,1), rgba(0,77,77,1), rgba(0,25,47,1), rgba(0,25,47,1), rgba(10,25,47,1));
        padding: 25px 30px;
        border-radius: 12px;
        margin-bottom: 30px;
        box-shadow: 0 8px 25px rgba(0,77,77,0.25);
    }

    .cart-header h2 {
        color: white;
        margin: 0;
        font-weight: 600;
    }

    .cart-table-wrapper {
        background: white;
        border-radius: 12px;
        overflow: visible;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }

    .cart-table {
        margin-bottom: 0;
        width: 100%;
        table-layout: auto;
    }

    .cart-table thead {
        background: linear-gradient(90deg, rgba(0,77,77,1), rgba(0,77,77,1), rgba(0,25,47,1), rgba(0,25,47,1), rgba(10,25,47,1));
    }

    .cart-table thead th {
        color: white !important;
        font-weight: 600;
        padding: 16px;
        border: none;
        text-transform: uppercase;
        font-size: 0.9rem;
        text-align: center;
        background: transparent;
    }

    .cart-table tbody tr {
        transition: all 0.3s ease;
        border-bottom: 1px solid rgba(0,77,77,0.1);
    }

    .cart-table tbody tr:hover {
        background: rgba(0,77,77,0.05);
        transform: translateX(3px);
    }

    .cart-table tbody td {
        padding: 18px 16px;
        vertical-align: middle;
        text-align: center;
        color: #333;
        background: white;
    }

    .cart-table tfoot tr {
        background: rgba(0,77,77,0.08);
        font-weight: 700;
        font-size: 1.1rem;
    }

    .cart-table tfoot th {
        padding: 20px 16px;
        color: #004d4d;
        border: none;
    }

    .cart-image img {
        width: 100px;
        height: auto;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.15);
        transition: transform 0.3s ease;
    }

    .cart-image img:hover {
        transform: scale(1.05);
    }

    .book-name {
        font-weight: 600;
        color: #004d4d;
    }

    .quantity-control {
        display: flex;
        gap: 8px;
        justify-content: center;
        align-items: center;
    }

    .quantity-btn {
        border-radius: 6px;
        background: linear-gradient(135deg, rgba(0,77,77,1), rgba(0,25,47,1));
        color: white;
        width: 40px;
        height: 40px;
        line-height: 40px;
        border: none;
        cursor: pointer;
        transition: all 0.3s ease;
        font-weight: 600;
    }

    .quantity-btn:hover {
        background: linear-gradient(135deg, rgba(0,25,47,1), rgba(10,25,47,1));
        transform: scale(1.1);
        box-shadow: 0 4px 8px rgba(0,77,77,0.3);
    }

    .quantity-input {
        width: 60px;
        border: 2px solid rgba(0,77,77,0.2);
        text-align: center;
        border-radius: 6px;
        padding: 8px;
        font-weight: 600;
        color: #004d4d;
    }

    .quantity-input:focus {
        outline: none;
        border-color: rgba(0,77,77,0.5);
    }

    .price-text {
        font-weight: 700;
        color: #d32f2f;
        font-size: 1.05rem;
    }

    .btn-payment {
        background: linear-gradient(135deg, #28a745, #20c997);
        color: white;
        padding: 10px 20px;
        border-radius: 8px;
        border: none;
        font-weight: 600;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
    }

    .btn-payment:hover {
        background: linear-gradient(135deg, #20c997, #28a745);
        transform: translateY(-2px);
        box-shadow: 0 6px 12px rgba(40,167,69,0.3);
        color: white;
    }

    .btn-delete {
        background: linear-gradient(135deg, #dc3545, #c82333);
        color: white;
        padding: 10px 20px;
        border-radius: 8px;
        border: none;
        font-weight: 600;
        transition: all 0.3s ease;
        cursor: pointer;
    }

    .btn-delete:hover {
        background: linear-gradient(135deg, #c82333, #bd2130);
        transform: translateY(-2px);
        box-shadow: 0 6px 12px rgba(220,53,69,0.3);
    }

    .total-amount {
        color: #d32f2f;
        font-size: 1.3rem;
        font-weight: 700;
    }

    /* Modal Styles */
    .modal-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.6);
        z-index: 9999;
        justify-content: center;
        align-items: center;
    }

    .modal-content {
        background: white;
        width: 400px;
        padding: 40px 30px;
        border-radius: 16px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.3);
        text-align: center;
        animation: modalSlideIn 0.3s ease;
    }


    .modal-icon {
        font-size: 70px;
        color: #dc3545;
        margin-bottom: 20px;
    }

    .modal-title {
        font-size: 1.3rem;
        font-weight: 600;
        color: #333;
        margin-bottom: 30px;
    }

    .modal-actions {
        display: flex;
        justify-content: center;
        gap: 15px;
    }

    .modal-btn {
        padding: 12px 30px;
        border-radius: 8px;
        border: none;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        color: white;
        display: inline-block;
    }

    .modal-btn-cancel {
        background: linear-gradient(135deg, #6c757d, #5a6268);
    }

    .modal-btn-cancel:hover {
        background: linear-gradient(135deg, #5a6268, #495057);
        transform: translateY(-2px);
        color: white;
    }

    .modal-btn-confirm {
        background: linear-gradient(135deg, #dc3545, #c82333);
    }

    .modal-btn-confirm:hover {
        background: linear-gradient(135deg, #c82333, #bd2130);
        transform: translateY(-2px);
        color: white;
    }

</style>

<div class="container cart-container">
    <div class="cart-header">
        <h2>🛒 Giỏ hàng của bạn</h2>
    </div>

    <div class="cart-table-wrapper">
        <table class="table cart-table">
            <thead>
                <tr>
                    <th>Ảnh</th>
                    <th>Tên sách</th>
                    <th>Số lượng</th>
                    <th>Đơn giá</th>
                    <th>Thanh toán</th>
                    <th>Xóa</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cart in Model)
                {
                    <tr>
                        <td class="cart-image">
                            <img src="~/Content/Image/@cart.Book.mainImage" alt="@cart.Book.BookName" />
                        </td>
                        <td>
                            <span class="book-name">@cart.Book.BookName</span>
                        </td>
                        <td>
                            <form action="~/Carts/UpdateQuantity" method="post">
                                @{
                                    string userId = "";
                                    if (User.Identity.IsAuthenticated)
                                    {
                                        userId = ViewBag.UserId;
                                    }
                                }
                                <input type="hidden" name="bookId" value="@cart.BookId" />
                                <input type="hidden" name="userId" value="@userId" />
                                <div class="quantity-control">
                                    <button type="submit" class="quantity-btn dec">-</button>
                                    <input type="number" name="quantity" min="1" value="@cart.Quantity" class="quantity-input" />
                                    <button type="submit" class="quantity-btn inc">+</button>
                                </div>
                            </form>
                        </td>
                        <td>
                            <span class="price-text">@cart.Book.Price VNĐ</span>
                        </td>
                        <td>
                            <a href="/Paying/Index?bookId=@cart.BookId&&userId=@userId" class="btn-payment">Thanh toán</a>
                        </td>
                        <td>
                            <button type="button" class="btn-delete DeleteCart" data-id="@cart.BookId">Xóa</button>
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="3">Tổng cộng:</th>
                    <th colspan="3">
                        <span class="total-amount">@ViewBag.TongTien VNĐ</span>
                    </th>
                </tr>
            </tfoot>
        </table>
    </div>

    <!-- Modal Delete -->
    <div id="modalOverlay" class="modal-overlay">
        <div class="modal-content">
            <div class="modal-icon">
                <i class="fa-solid fa-circle-xmark"></i>
            </div>
            <div class="modal-title">Bạn có chắc muốn xóa sản phẩm này?</div>
            <div class="modal-actions">
                <a href="/Carts/Index?userId=@ViewBag.UserId" class="modal-btn modal-btn-cancel">
                    Hủy
                </a>
                <a id="dataLink" href="#" class="modal-btn modal-btn-confirm">
                    Xóa
                </a>
            </div>
        </div>
    </div>
</div>

<script>
    // Delete Cart Modal
    document.querySelectorAll('.DeleteCart').forEach(btn => {
        btn.addEventListener('click', () => {
            const Link = btn.getAttribute('data-id');
            document.getElementById('modalOverlay').style.display = "flex";
            document.getElementById('dataLink').href = `/Carts/DeleteCart?bookId=${Link}&&userId=@ViewBag.UserId`;
        });
    });

    document.getElementById('modalOverlay').addEventListener('click', (e) => {
        if (e.target === e.currentTarget) {
            e.currentTarget.style.display = "none";
        }
    });

    // Decrease Quantity
    document.querySelectorAll('.dec').forEach(btn => {
        btn.addEventListener('click', (e) => {
            e.preventDefault();
            const form = btn.closest("form");
            let val = form.querySelector("input[name='quantity']");
            let inval = parseInt(val.value);
            if (inval <= 1) {
                val.value = 1;
            } else {
                val.value = inval - 1;
            }
            form.submit();
        });
    });

    // Increase Quantity
    document.querySelectorAll('.inc').forEach(btn => {
        btn.addEventListener('click', (e) => {
            e.preventDefault();
            const form = btn.closest("form");
            let val = form.querySelector("input[name='quantity']");
            let inval = parseInt(val.value);
            val.value = inval + 1;
            form.submit();
        });
    });
</script>