@model LTW_Ban_Sach.Identity.AppUser
@{
    ViewBag.Title = "ProFile";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
}
<div style="margin-top: 80px; margin-bottom: 20px;" class="p-3">

    <div class="container">
        <div class="row mb-5" style="border-top: 1px solid rgb(10,25,47); border-bottom: 1px solid rgb(10,25,47); padding: 10px;">
            <div class="col-2">
                <a href="/Home/Index"><i class="fa-solid fa-arrow-left" style="font-size: 25px;color: rgb(10,25,47); line-height: 30px;"></i></a>
            </div>
            <div class="col-10" style="padding-left: 200px;">
                <h2 style="font-size: 40px; line-height:30px; color: rgba(10,25,47, 0.9)">My Profile</h2>
            </div>
        </div>
    </div>

    <div class="container">

        <div class="col-2" style="width: 200px; height:200px; border-radius: 100px; background: url('/Content/Image/@Model.Avatar'); background-size: cover; float: left"></div>
        <div class="col-10 mt-5 mb-5" style="padding-left: 200px; float: right; width: calc(100% - 200px)">
            <p><strong>Username:</strong> @Model.UserName</p>
            <p><strong>Email:</strong> @Model.Email</p>
            <p><strong>Phone Number:</strong> @Model.PhoneNumber</p>
            <p><strong>Address:</strong> @Model.Address</p>
        </div>
        <div class="d-flex" style="clear: both">
            <div class="me-3"><a href="/Account/EditProfile?userId=@Model.Id" class="btn" id="LogOutButton" style="background-color: rgba(80, 193, 120, 0.4);  width: 200px;" onclick="LogOut">Change Information</a></div>
            <div class="me-3"><button class="btn" id="LogOutButton" style="background-color: rgba(80, 193, 120, 0.4);  width: 200px;" onclick="LogOut">Change Password</button></div>
            <div class="me-3"><a class="btn" id="LogOutButton" style="background-color: rgba(80, 193, 120, 0.4);  width: 200px; " onclick="LogOut" href="/Account/Logout">Log out</a></div>
        </div>

    </div>


</div>