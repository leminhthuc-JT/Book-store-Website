@model LTW_Ban_Sach.Identity.AppUser
@{
    ViewBag.Title = "ProFile";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
}

<link rel="stylesheet" href="~/Content/Profile.css" />

<div class="profile-container">
    <div class="profile-header">
        <a href="/Home/Index" class="back-btn">
            <i class="fa-solid fa-arrow-left"></i>
        </a>
        <h2>MY PROFILE</h2>
    </div>

    <div class="profile-body">
        @if (TempData["SuccessMessage"] != null)
        {
            <div id="alertSuccess" class="alert alert-success">
                <i class="fa-solid fa-check-circle"></i> @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div id="alertError" class="alert alert-danger">
                <i class="fa-solid fa-exclamation-circle"></i> @TempData["ErrorMessage"]
            </div>
        }


        <div class="profile-content">
            <div class="profile-avatar">
                <div class="avatar-wrapper">
                    <img src="/Content/Image/@Model.Avatar" alt="Avatar" onerror="this.src='/Content/Image/default-avatar.png'" />
                    <div class="avatar-overlay">
                        <i class="fa-solid fa-camera"></i>
                        <div style="font-size: 12px; margin-top: 5px;">Đổi ảnh</div>
                    </div>
                </div>

                @using (Html.BeginForm("UpdateAvatar", "Account", FormMethod.Post, new { enctype = "multipart/form-data" }))
                {
                    @Html.AntiForgeryToken()
                    @Html.Hidden("userId", Model.Id)

                    <label for="avatarInput" class="btn-change-avatar">
                        <i class="fa-solid fa-camera"></i> Chọn ảnh mới
                    </label>
                    <input type="file" id="avatarInput" name="avatar" accept="image/*" style="display: none;" onchange="this.form.submit()" />
                }
            </div>

            <div class="profile-info">
                <div class="info-item">
                    <div class="info-label">
                        <i class="fa-solid fa-user"></i>
                        <span>Tên đăng nhập</span>
                    </div>
                    <div class="info-value">@Model.UserName</div>
                </div>

                <div class="info-item">
                    <div class="info-label">
                        <i class="fa-solid fa-envelope"></i>
                        <span>Email</span>
                    </div>
                    <div class="info-value">@Model.Email</div>
                </div>

                <div class="info-item">
                    <div class="info-label">
                        <i class="fa-solid fa-phone"></i>
                        <span>Số điện thoại</span>
                    </div>
                    <div class="info-value">@Model.PhoneNumber</div>
                </div>

                <div class="info-item">
                    <div class="info-label">
                        <i class="fa-solid fa-location-dot"></i>
                        <span>Địa chỉ</span>
                    </div>
                    <div class="info-value">@Model.Address</div>
                </div>
            </div>
        </div>

        <div class="profile-actions">
            <a href="/Account/EditProfile?userId=@Model.Id" class="profile-btn btn-edit">
                <i class="fa-solid fa-pen-to-square"></i>
                Chỉnh sửa thông tin
            </a>

            <a href="/Account/ChangePassWord?userId=@Model.Id" class="profile-btn btn-password">
                <i class="fa-solid fa-key"></i>
                Đổi mật khẩu
            </a>

            <a href="/Account/Logout" class="profile-btn btn-logout">
                <i class="fa-solid fa-right-from-bracket"></i>
                Đăng xuất
            </a>
        </div>
    </div>
</div>

<script>
    setTimeout(function () {
        var alertBox = document.getElementById("alertSuccess");
        if (alertBox) {
            alertBox.style.transition = "opacity 0.5s";
            alertBox.style.opacity = "0";
            setTimeout(() => alertBox.remove(), 500);
        }
    }, 3000);
    setTimeout(function () {
        var alertBox = document.getElementById("alertError");
        if (alertBox) {
            alertBox.style.transition = "opacity 0.5s";
            alertBox.style.opacity = "0";
            setTimeout(() => alertBox.remove(), 500);
        }
    }, 3000);
</script>