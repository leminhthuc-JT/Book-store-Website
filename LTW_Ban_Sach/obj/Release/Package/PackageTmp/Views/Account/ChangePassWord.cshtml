@model LTW_Ban_Sach.ViewModel.ChangePasswordModel
@{
    ViewBag.Title = "ChangePassWord";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
}

<link rel="stylesheet" href="~/Content/EditProfile.css" />

<div class="edit-profile-container">
    <div class="edit-profile-header">
        <a href="/Account/Profile?userId=@ViewBag.UserId" class="back-btn">
            <i class="fa-solid fa-arrow-left"></i>
        </a>
        <h2>ĐỔI MẬT KHẨU</h2>
    </div>

    <div class="edit-profile-body">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                <i class="fa-solid fa-check-circle"></i> @TempData["SuccessMessage"]
            </div>
        }


        @using (Html.BeginForm("ChangePassWord", "Account", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            <input type="hidden" name="userId" value="@ViewBag.UserId" />

            <div class="form-section">
                <label>
                    <i class="fa-solid fa-key"></i>
                    Mật khẩu cũ: 
                </label>
                <div class="input-wrapper">
                    <i class="fa-solid fa-key"></i>
                    @Html.PasswordFor(r => r.CurrentPassword, new { @class = "form-control", placeholder = "Nhập mật khẩu cũ", type = "password" })
                </div>
                @Html.ValidationMessageFor(r => r.CurrentPassword, "", new { @class = "text-danger" })
            </div>
            <div class="form-section">
                <label>
                    <i class="fa-solid fa-key"></i>
                    Mật khẩu mới: 
                </label>
                <div class="input-wrapper">
                    <i class="fa-solid fa-key"></i>
                    @Html.PasswordFor(r => r.NewPassword, new { @class = "form-control", placeholder = "Nhập mật khẩu mới", type = "password" })
                </div>
                @Html.ValidationMessageFor(r => r.NewPassword, "", new { @class = "text-danger" })
            </div>
            <div class="form-section">
                <label>
                    <i class="fa-solid fa-key"></i>
                    Nhập lại mật khẩu: 
                </label>
                <div class="input-wrapper">
                    <i class="fa-solid fa-key"></i>
                    @Html.PasswordFor(r => r.ConfirmNewPassword, new { @class = "form-control", placeholder = "Nhập lại mật khẩu mới", type = "password" })
                </div>
                @Html.ValidationMessageFor(r => r.ConfirmNewPassword, "", new { @class = "text-danger" })
            </div>
            <div class="form-section">
                
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-submit">
                    <i class="fa-solid fa-floppy-disk"></i>
                    Lưu thay đổi
                </button>
                <a href="/Account/Profile?userId=@ViewBag.UserId" class="btn-cancel">
                    <i class="fa-solid fa-xmark"></i>
                    Hủy bỏ
                </a>
            </div>
        }
    </div>
</div>

