@model LTW_Ban_Sach.Models.Books
@{
    ViewBag.Title = "Delete";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

<style>
    :root {
        --gradient-danger: linear-gradient(90deg, #e74c3c, #c0392b);
        --danger-color: #e74c3c;
        --primary-color: rgba(0,77,77,1);
    }

    .delete-container {
        max-width: 900px;
        margin: 30px auto;
        padding: 0 20px;
    }

    .page-header {
        background: var(--gradient-danger);
        color: white;
        padding: 20px;
        border-radius: 15px 15px 0 0;
        box-shadow: 0 5px 20px rgba(231, 76, 60, 0.3);
        display: flex;
        align-items: center;
        gap: 20px;
    }

    .back-btn {
        width: 45px;
        height: 45px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        text-decoration: none;
        transition: all 0.3s ease;
        margin-top: 35px;
    }

    .back-btn:hover {
        background: rgba(255, 255, 255, 0.3);
        transform: translateX(-5px);
        color: white;
    }

    .page-header h2 {
        margin: 0;
        font-size: 28px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 12px;
        margin-top: 35px;
    }

    .delete-card {
        background: white;
        border-radius: 0 0 15px 15px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        overflow: hidden;
    }

    .warning-banner {
        background: linear-gradient(135deg, #fff3cd 0%, #ffeaa7 100%);
        border-left: 5px solid #ffc107;
        padding: 20px 30px;
        display: flex;
        align-items: center;
        gap: 15px;
        border-bottom: 2px solid #f8d7da;
    }

    .warning-banner i {
        font-size: 36px;
        color: #856404;
    }

    .warning-content h3 {
        margin: 0 0 8px 0;
        color: #856404;
        font-size: 20px;
        font-weight: 700;
    }

    .warning-content p {
        margin: 0;
        color: #856404;
        font-size: 14px;
    }

    .book-preview {
        display: grid;
        grid-template-columns: 250px 1fr;
        gap: 30px;
        padding: 30px;
        background: #f8f9fa;
        border-bottom: 2px solid #e0e0e0;
    }

    .book-image-section {
        text-align: center;
    }

    .book-cover {
        width: 100%;
        max-width: 200px;
        height: auto;
        min-height: 280px;
        object-fit: cover;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        border: 4px solid white;
    }

    .book-info-section {
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    .book-title {
        font-size: 28px;
        font-weight: 700;
        color: #2c3e50;
        margin: 0;
    }

    .book-category {
        display: inline-block;
        padding: 6px 15px;
        background: var(--primary-color);
        color: white;
        border-radius: 15px;
        font-size: 13px;
        font-weight: 600;
        width: fit-content;
    }

    .details-section {
        padding: 30px;
    }

    .section-title {
        color: #2c3e50;
        font-size: 18px;
        font-weight: 600;
        margin-bottom: 20px;
        padding-bottom: 10px;
        border-bottom: 2px solid #e0e0e0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .section-title i {
        color: var(--danger-color);
    }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
    }

    .info-item {
        background: #f8f9fa;
        padding: 15px 20px;
        border-radius: 10px;
        border-left: 4px solid var(--danger-color);
    }

    .info-label {
        font-size: 12px;
        color: #666;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 5px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .info-label i {
        color: var(--danger-color);
    }

    .info-value {
        font-size: 15px;
        color: #2c3e50;
        font-weight: 500;
    }

    .description-box {
        background: #f8f9fa;
        padding: 20px;
        border-radius: 10px;
        border: 2px solid #e0e0e0;
        line-height: 1.6;
        color: #333;
        font-size: 14px;
        max-height: 150px;
        overflow-y: auto;
        margin-top: 15px;
    }

    .form-actions {
        display: flex;
        gap: 15px;
        padding: 25px 30px;
        background: #fff5f5;
        border-top: 3px solid var(--danger-color);
    }

    .btn-delete, .btn-cancel {
        padding: 14px 30px;
        border-radius: 10px;
        font-size: 15px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s ease;
        border: none;
        cursor: pointer;
        text-decoration: none;
    }

    .btn-delete {
        background: var(--gradient-danger);
        color: white;
        width: fit-content;
    }

    .btn-delete:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(231, 76, 60, 0.4);
    }

    .btn-cancel {
        background: #6c757d;
        color: white;
    }

    .btn-cancel:hover {
        background: #5a6268;
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(108, 117, 125, 0.3);
        color: white;
        text-decoration: none;
    }

    .danger-icon-wrapper {
        width: 60px;
        height: 60px;
        background: rgba(231, 76, 60, 0.1);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 15px;
    }

    .danger-icon-wrapper i {
        font-size: 30px;
        color: var(--danger-color);

</style>

<div class="delete-container">
    <div class="page-header">
        <a href="@Url.Action("Index")" class="back-btn">
            <i class="fa-solid fa-arrow-left"></i>
        </a>
        <h2>
            <i class="fa-solid fa-trash-can"></i>
            Xóa Sách
        </h2>
    </div>

    <div class="delete-card">
        <!-- Warning Banner -->
        <div class="warning-banner">
            <i class="fa-solid fa-triangle-exclamation"></i>
            <div class="warning-content">
                <h3>Cảnh báo: Thao tác không thể hoàn tác!</h3>
                <p>Bạn có chắc chắn muốn xóa sách này? Dữ liệu sẽ bị xóa vĩnh viễn và không thể khôi phục.</p>
            </div>
        </div>

        <!-- Book Preview -->
        <div class="book-preview">
            <div class="book-image-section">
                <img class="book-cover"
                     src="@Url.Content("~/Content/Image/" + Model.mainImage)"
                     alt="@Model.BookName"
                     onerror="this.src='https://via.placeholder.com/200x280?text=No+Image'" />
            </div>

            <div class="book-info-section">
                <div class="danger-icon-wrapper">
                    <i class="fa-solid fa-book-skull"></i>
                </div>

                <span class="book-category">
                    <i class="fa-solid fa-tag"></i>
                    @Html.DisplayFor(model => model.Categories.CateName)
                </span>

                <h1 class="book-title">@Html.DisplayFor(model => model.BookName)</h1>

                <div style="display: flex; align-items: center; gap: 10px; color: #666;">
                    <i class="fa-solid fa-user-pen"></i>
                    <span style="font-size: 16px; font-weight: 500;">@Html.DisplayFor(model => model.Author)</span>
                </div>

                <div style="display: flex; align-items: center; gap: 10px; color: var(--danger-color); font-size: 24px; font-weight: 700;">
                    <i class="fa-solid fa-dollar-sign"></i>
                    <span>@Html.DisplayFor(model => model.Price) đ</span>
                </div>
            </div>
        </div>

        <!-- Details Section -->
        <div class="details-section">
            <div class="section-title">
                <i class="fa-solid fa-circle-info"></i>
                Thông tin chi tiết sẽ bị xóa
            </div>

            <div class="info-grid">
                <div class="info-item">
                    <div class="info-label">
                        <i class="fa-solid fa-book"></i>
                        Tên sách
                    </div>
                    <div class="info-value">@Html.DisplayFor(model => model.BookName)</div>
                </div>

                <div class="info-item">
                    <div class="info-label">
                        <i class="fa-solid fa-user-pen"></i>
                        Tác giả
                    </div>
                    <div class="info-value">@Html.DisplayFor(model => model.Author)</div>
                </div>

                <div class="info-item">
                    <div class="info-label">
                        <i class="fa-solid fa-building"></i>
                        Nhà xuất bản
                    </div>
                    <div class="info-value">@Html.DisplayFor(model => model.Publisher)</div>
                </div>

                <div class="info-item">
                    <div class="info-label">
                        <i class="fa-solid fa-calendar"></i>
                        Năm xuất bản
                    </div>
                    <div class="info-value">@Html.DisplayFor(model => model.PublicationYear)</div>
                </div>

                <div class="info-item">
                    <div class="info-label">
                        <i class="fa-solid fa-dollar-sign"></i>
                        Giá bán
                    </div>
                    <div class="info-value">@Html.DisplayFor(model => model.Price) đ</div>
                </div>

                <div class="info-item">
                    <div class="info-label">
                        <i class="fa-solid fa-tag"></i>
                        Thể loại
                    </div>
                    <div class="info-value">@Html.DisplayFor(model => model.Categories.CateName)</div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div style="margin-top: 25px;">
                    <div class="info-label" style="font-size: 14px; margin-bottom: 10px;">
                        <i class="fa-solid fa-align-left"></i>
                        Mô tả
                    </div>
                    <div class="description-box">
                        @Html.DisplayFor(model => model.Description)
                    </div>
                </div>
            }
        </div>

        <!-- Form Actions -->
        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            <div class="form-actions">
                <button type="submit" class="btn-delete" onclick="return confirm('Bạn có chắc chắn muốn xóa sách này? Hành động này không thể hoàn tác!');">
                    <i class="fa-solid fa-trash-can"></i>
                    Xác nhận xóa
                </button>
                <a href="@Url.Action("Index")" class="btn-cancel">
                    <i class="fa-solid fa-xmark"></i>
                    Hủy bỏ
                </a>
            </div>
        }
    </div>
</div>